# Docker published port
APP_PORT=3000

# Set TRUST_PROXY=1 only when you are behind Nginx/Caddy/Traefik
TRUST_PROXY=

# For direct access over http://SERVER_IP:3000 keep this as false.
# If you later put the app behind HTTPS, change it to true.
AUTH_COOKIE_SECURE=false

# Session lifetime in hours
AUTH_SESSION_TTL_HOURS=12

# Sliding session refresh interval (minutes): extiende expiración si hay actividad
AUTH_SESSION_SLIDE_MINUTES=5

# HTTP access log one JSON line per request (false para desactivar)
LOG_HTTP=true

# PostgreSQL (opcional): auditoría security_audit y readiness estricto
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional bootstrap admin
AUTH_INITIAL_EMAIL=
AUTH_INITIAL_PASSWORD=
AUTH_INITIAL_NAME=Administrador

# Optional one-time setup token
AUTH_SETUP_TOKEN=
