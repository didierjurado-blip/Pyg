# Docker published port
APP_PORT=3000

# If you deploy behind Nginx/Caddy/Traefik, keep TRUST_PROXY=1
TRUST_PROXY=1

# For a public VPS with HTTPS this must be true.
# For local http://localhost tests use false.
AUTH_COOKIE_SECURE=true

# Session lifetime in hours
AUTH_SESSION_TTL_HOURS=12

# Option 1: bootstrap the first admin automatically on first start
AUTH_INITIAL_EMAIL=admin@tuempresa.com
AUTH_INITIAL_PASSWORD=Cambia_Esta_Clave_2026!
AUTH_INITIAL_NAME=Administrador

# Option 2: use a one-time setup token instead of bootstrap credentials
AUTH_SETUP_TOKEN=CAMBIA_ESTE_TOKEN_SUPER_LARGO
